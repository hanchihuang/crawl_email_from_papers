# Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# arXiv API
ARXIV_CATEGORIES=econ.GN q-fin.GN q-fin.CP q-fin.ST q-fin.PM q-fin.TR

# Rate limiting
MAX_EMAILS_PER_HOUR=50
MAX_REQUESTS_PER_MINUTE=30

# Cleanup
DELETE_PAPERS_AFTER_EXTRACT=True
MAX_PAPER_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/logs/crawler.log

# Storage
PAPER_DOWNLOAD_DIR=data/papers
AUTHOR_DATA_FILE=data/authors/authors.json
PROCESSED_IDS_FILE=data/authors/processed.txt
EMAIL_QUEUE_FILE=data/authors/email_queue.json
